# Backend runtime
ARTIFACTS_DIR=artifacts
FRONTEND_ORIGIN=http://localhost:3000

# LLM fallback provider for backend env mode.
# The Tour UI can also send a per-request provider/api key.
LLM_PROVIDER=mock

# Optional LLM keys
GEMINI_API_KEY=
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
GROQ_API_KEY=
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# Optional Supabase persistence for saved tour projects
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_TOUR_PROJECTS_TABLE=tour_projects
SUPABASE_STORAGE_BUCKET=3D

# Optional VieNeu-TTS
VIENEU_TTS_VOICE=Ngọc Lan
# VIENEU_TTS_MODE=remote
# VIENEU_TTS_API_BASE=http://127.0.0.1:23333/v1
# VIENEU_TTS_MODEL=pnnbao-ump/VieNeu-TTS-v2
# VIENEU_TTS_EMOTION=storytelling
